ersion: '3.8'

services:
  backend:
    build: ./backend  
    ports:
      - "8801:8801" 
    env_file:
      - .env
    depends_on:
      - db

  frontend:
    build: ./frontend # ścieżka do folderu z frontendem
    ports:
      - "8802:8802"
    depends_on:
      - backend # frontend startuje po backendzie

  db:
    image: mysql:8
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: eduenroll
    ports:
      - "3306:3306"
