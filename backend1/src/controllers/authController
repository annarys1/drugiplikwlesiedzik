import jwt from 'jsonwebtoken';
import { Request, Response } from 'express';
import bcrypt from 'bcrypt';
import db from '../config/db';


export const loginUser = async (req: Request, res: Response): Promise<void> => {
  try {
    const { email, password } = req.body;

    // 1. Walidacja pól
    if (!email || !password) {
      res.status(400).json({ message: 'Email i hasło są wymagane!' });
      return;
    }

    // 2. Szukanie użytkownika w bazie danych
    const [users]: any = await db.query('SELECT * FROM Users WHERE email = ?', [email]);
    if (users.length === 0) {
      res.status(401).json({ message: 'Nieprawidłowy e-mail lub hasło!' });
      return;
    }

    const user = users[0];

  
    const isPasswordValid = await bcrypt.compare(password, user.password);
    if (!isPasswordValid) {
      res.status(401).json({ message: 'Nieprawidłowy e-mail lub hasło!' });
      return;
    }


    const JWT_SECRET = process.env.JWT_SECRET || 'super_tajny_klucz_rezerwowy';
    const token = jwt.sign(
      { id: user.id, email: user.email, role: user.role }, 
      JWT_SECRET,
      { expiresIn: '24h' }
    );

   
    res.status(200).json({
      message: 'Logowanie zakończone sukcesem!',
      token,
      user: {
        id: user.id,
        email: user.email,
        firstName: user.name,
        lastName: user.surename,
        role: user.funkcja
      }
    });
  } catch (error: any) {
    console.error('Błąd logowania:', error.message);
    res.status(500).json({ message: 'Błąd serwera podczas logowania.' });
  }
};